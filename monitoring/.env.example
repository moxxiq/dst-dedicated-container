# Copy to .env in this directory after the first Beszel hub login.
#
# The Beszel hub generates an SSH public key per-agent on first "Add system".
# Paste that key here (single line, starts with "ssh-ed25519" or similar)
# so the agent accepts the hub's connection.
#
# Leave blank on initial boot — the agent will come up but refuse inbound
# connections until a key is set. That's the secure default.

BESZEL_AGENT_KEY=
