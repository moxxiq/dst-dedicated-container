# Copy to .env and fill in. Read by run-dst.sh and docker-compose.yml.
# DO NOT commit .env — it contains secrets. (.env is in .gitignore.)
#
# This file is also the source the admin web panel will use to
# regenerate a downloadable bootstrap script for re-provisioning a VPS.

# --- Cluster ---
CLUSTER_NAME=qkation-cooperative

# Cluster token from https://accounts.klei.com/account/game/servers
# Leave blank if saves/<CLUSTER_NAME>/cluster_token.txt is already populated.
CLUSTER_TOKEN=

# --- Cloudflare R2 backup (optional — leave all blank to disable R2) ---
# R2 dashboard → Manage API tokens → create a token with Object Read & Write.
R2_ACCOUNT_ID=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# --- Behavior ---
# 1 = run `steamcmd +app_update 343050 validate` on every container start.
# 0 = skip (faster restart, but you must manually update when Klei patches).
AUTO_UPDATE=1

# --- Admin web panel (Phase 3) ---
# HTTP Basic auth for the FastAPI panel on :8080.
# ADMIN_USER defaults to "admin" if unset. ADMIN_PASSWORD is REQUIRED —
# leaving it blank makes every admin endpoint return 500 (fail-closed).
ADMIN_USER=admin
ADMIN_PASSWORD=
