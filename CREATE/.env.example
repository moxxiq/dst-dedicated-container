# --- Cluster ---
CLUSTER_NAME=qkation-cooperative

# Cluster token from https://accounts.klei.com/account/game/servers
CLUSTER_TOKEN=

# --- Cloudflare R2 backup  ---
R2_ACCOUNT_ID=
R2_BUCKET=dst
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# --- Admin web panel ---
# HTTP Basic auth for the FastAPI panel on :8080.
# ADMIN_USER defaults to "admin" if unset. ADMIN_PASSWORD is REQUIRED —
ADMIN_USER=admin
ADMIN_PASSWORD=12345678
